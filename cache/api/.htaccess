# Cached API JSON responses live here. They're a server-side
# performance helper, not user data — block direct browser access so a
# scraper can't enumerate them by guessing IDs.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

# Defense-in-depth: never execute PHP from this folder.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<FilesMatch "\.(php|phtml|phar|cgi|pl|py|sh)$">
    SetHandler text/plain
</FilesMatch>
