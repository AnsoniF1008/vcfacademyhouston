# Uploaded content (jugador del mes photos)
assets/uploads/*
!assets/uploads/.gitkeep
!assets/uploads/.htaccess

# Page cache (HTML snapshots, regenerated automatically)
cache/page/*
!cache/page/.gitkeep
!cache/page/.htaccess
# Circuit breaker state file (managed at runtime by config/database.php)
cache/db_blocked_until.txt
!cache/.htaccess

# Export for migration (SQL dumps and build)
export/
valencia-website.zip

# Backup from production (Hostinger)
backup/

# Config con credenciales (no subir a git)
config/database.local.php
config/deploy-credentials.php
config/deploy-ftp.txt
config/site.php

# Reference/import working folders (not part of the live site)
_import_*/
_redesign_*/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.sublime-*
