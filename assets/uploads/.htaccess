# Defense in depth: this folder stores user-uploaded media (photos, videos).
# Even if validation fails upstream, the server must NOT execute PHP/CGI here.

# Apache 2.2 / 2.4 (mod_php)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php5.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# Strip handlers and remove dangerous file types from being served as code.
<IfModule mod_mime.c>
    RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phps .pl .py .jsp .asp .aspx .cgi .fcgi
    RemoveType .php .phtml .php3 .php4 .php5 .php7 .phps .pl .py .jsp .asp .aspx .cgi .fcgi
    AddType text/plain .php .phtml .php3 .php4 .php5 .php7 .phps .pl .py .jsp .asp .aspx .cgi .fcgi
</IfModule>

# Block direct access to source-like extensions even by name.
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|pl|py|jsp|asp|aspx|cgi|fcgi|sh|bash|env|ini|conf|sql|bak|swp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Disable directory listing.
Options -Indexes -ExecCGI

# Force download for unknown types instead of executing.
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
