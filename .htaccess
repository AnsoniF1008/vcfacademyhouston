# VCF Academy Houston - Performance (mobile & desktop)
# Hostinger: activa "LiteSpeed Cache" o "Cache" en el panel para mejor puntuación.

# Custom error page
ErrorDocument 404 /404.php

# Block deploy.php from public access
<Files "deploy.php">
    Order Allow,Deny
    Deny from all
</Files>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Security headers (apply to all responses)
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

    # HSTS: enforce HTTPS for 6 months. Enable preload only after confirming the site is reachable on HTTPS reliably.
    Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains"

    # Content Security Policy:
    # - 'unsafe-inline' on scripts/styles is still required: the templates use
    #   ~13 inline <script> blocks, ~31 inline event handlers (onsubmit/onload/
    #   onerror) and ~194 inline style="" attributes. Removing it needs a
    #   nonce migration AND refactoring every inline handler (nonces don't
    #   authorise on*= attributes) and every style attribute — a dedicated,
    #   separately-tested effort, not a header tweak. See docs/CSP-NONCE-PLAN.md.
    # - object-src 'none': block <object>/<embed>/<applet> injection (unused here).
    # - upgrade-insecure-requests: auto-upgrade any stray http subresource to https.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' https: data: blob:; media-src 'self' https: blob:; connect-src 'self'; object-src 'none'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
</IfModule>

# Block access to dotfiles, source backups and configuration files at the root.
<FilesMatch "^\.(env|git|gitignore|htaccess)$|^.+\.(bak|swp|sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block aggressive crawlers/scrapers ────────────────────────────────
# These bots crawl with very high frequency on shared hosting and
# regularly drive sites past the per-user MySQL connection limits without
# providing any traffic value (they don't drive users to vcfacademyhouston.com).
# Real search engines (Google, Bing, DuckDuckGo, Yandex) are NOT blocked.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|MJ12bot|DotBot|PetalBot|Bytespider|DataForSeoBot|BLEXBot|MegaIndex|SeekportBot|serpstatbot|Barkrowler|ZoominfoBot|VelenPublicWebCrawler|YisouSpider|sogou|Sogou) [NC]
    RewriteRule .* - [F,L]
</IfModule>
